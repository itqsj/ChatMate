{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Electron: Main",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "start:main"
      ],
      "port": 5858,
      "timeout": 30000,
      "console": "integratedTerminal",
      "sourceMapPathOverrides": {
        "webpack://electron-react-boilerplate/./src/*": "${workspaceFolder}/src/*",
        "webpack://electron-react-boilerplate/src/*": "${workspaceFolder}/src/*"
      },
      "outFiles": [
        "${workspaceFolder}/.erb/dll/**/*.js",
        "${workspaceFolder}/release/app/dist/**/*.js"
      ]
    },
    {
      "name": "Electron: Renderer",
      "type": "chrome",
      "request": "attach",
      "port": 9223,
      "webRoot": "${workspaceFolder}",
      "timeout": 15000
    }
  ],
  "compounds": [
    {
      "name": "Electron: All",
      "configurations": [
        "Electron: Main",
        "Electron: Renderer"
      ]
    }
  ]
}